{
  "name": "chat-app-svelte",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "check": "bunx svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "format": "bunx prettier . --write"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tsconfig/svelte": "5.0.8",
    "@types/bun": "1.3.12",
    "prettier": "3.8.2",
    "prettier-plugin-svelte": "3.5.1",
    "svelte": "5.55.3",
    "svelte-check": "4.4.6",
    "vite": "8.0.8"
  },
  "dependencies": {
    "@fontsource/inter": "5.2.8",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.2",
    "marked": "18.0.0",
    "tailwindcss": "4.2.2"
  }
}
