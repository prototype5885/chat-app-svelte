{
  "name": "chat-app-svelte",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "check": "bunx svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "format": "bunx prettier . --write"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@tsconfig/svelte": "5.0.8",
    "@types/bun": "1.3.10",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "3.5.1",
    "svelte": "5.53.11",
    "svelte-check": "4.4.5",
    "typescript": "5.9.3",
    "vite": "8.0.0"
  },
  "dependencies": {
    "@fontsource/inter": "5.2.8",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.1",
    "marked": "17.0.4",
    "tailwindcss": "4.2.1"
  }
}
